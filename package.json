{
  "name": "@wyverncw/munch",
  "version": "1.0.0",
  "description": "Augmented cognitive agent skill & MCP server",
  "homepage": "https://github.com/WyvernCW/MunchsPlugin",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WyvernCW/MunchsPlugin.git"
  },
  "bugs": "https://github.com/WyvernCW/MunchsPlugin/issues",
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "bin": {
    "munch": "mcp-server/build/index.js",
    "munch-setup": "install.js"
  },
  "scripts": {
    "setup": "node install.js",
    "doctor": "node install.js doctor",
    "uninstall:munch": "node install.js uninstall",
    "setup:dry-run": "node install.js setup --dry-run",
    "generate": "node scripts/generate-artifacts.js && node scripts/generate-reference-catalog.js",
    "generate:check": "node scripts/generate-artifacts.js --check && node scripts/generate-reference-catalog.js --check",
    "references:normalize": "node scripts/normalize-references.js",
    "policy:compile": "npm run compile && node scripts/compile-policy.js",
    "evaluate": "node scripts/run-evaluation.js",
    "lint": "eslint api src install.js lib scripts tests skill/munch/scripts",
    "coverage": "c8 --exclude=mcp-server/build/** --check-coverage --lines 55 --functions 55 --branches 50 node --test tests/advanced-runtime.test.js tests/frontend-build.test.js tests/http.integration.test.js tests/mcp.integration.test.js tests/preference-engine.test.js tests/validators.test.js tests/vercel.integration.test.js",
    "audit": "npm audit --omit=dev && npm audit --omit=dev --prefix mcp-server",
    "pack:check": "npm pack --dry-run",
    "compile": "tsc -p mcp-server/tsconfig.json",
    "build": "npm run compile && vite build",
    "dev": "vite",
    "start": "npm run --prefix mcp-server start",
    "test": "node --test tests/*.test.js",
    "test:web": "node scripts/browser-test.mjs",
    "verify": "npm run generate:check && npm run lint && npm run compile && npm run coverage && node skill/munch/scripts/hallucination_guard.js ."
  },
  "files": [
    "mcp-server/build",
    "skill",
    "opencode-plugin",
    "lib",
    "scripts",
    "install.js",
    "package.json",
    "plugin.json",
    "marketplace.json",
    ".mcp.json",
    "munch_plugin_logo.png",
    "munch_plugin_logo.svg",
    "AGENT.md",
    "AGENTS.md",
    "GEMINI.md",
    "CLAUDE.md",
    ".codex-plugin"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "mcp-handler": "^1.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "@vitejs/plugin-react": "^6.0.2",
    "c8": "^11.0.0",
    "eslint": "^10.4.1",
    "eslint-plugin-react": "^7.37.5",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "keywords": [
    "mcp",
    "munch",
    "agent",
    "skill"
  ],
  "author": "cika",
  "license": "MIT"
}
