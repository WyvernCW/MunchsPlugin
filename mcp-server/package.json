{
  "name": "@cika/munch-mcp",
  "version": "1.0.0",
  "description": "MCP server for the munch augmented cognitive agent skill",
  "type": "module",
  "bin": {
    "munch-mcp": "./build/index.js"
  },
  "scripts": {
    "build": "tsc && node -e \"if (process.platform !== 'win32') require('child_process').execSync('chmod 755 build/index.js')\"",
    "dev": "tsc --watch",
    "start": "node build/index.js"
  },
  "files": ["build", "README.md"],
  "keywords": ["mcp", "munch", "agent", "skill", "claude", "codex", "opencode"],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  }
}
