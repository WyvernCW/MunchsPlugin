<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="Munch"
    Version="$(var.ProductVersion)"
    Manufacturer="WyvernCW"
    UpgradeCode="c2e8e4a0-3f8a-4a5e-9b1d-7e8f9a0b1c2d"
    Scope="perUser"
    Compressed="yes">

    <MajorUpgrade DowngradeErrorMessage="A newer version of Munch is already installed." />

    <Property Id="ARPPRODUCTICON" Value="icon.ico" />
    <Property Id="ARPHELPLINK" Value="https://github.com/WyvernCW/MunchsPlugin" />
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/WyvernCW/MunchsPlugin" />

    <Icon Id="icon.ico" SourceFile="$(var.SourceDir)munch_plugin_logo.png" />

    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="ProgramsDir" Name="Programs">
        <Directory Id="INSTALLDIR" Name="Munch">
          <Component Id="InstallDirComponent" Guid="a1b2c3d4-e5f6-7890-abcd-ef1234567890" Bitness="always64">
            <RemoveFolder Id="RemoveInstallDir" On="uninstall" />
            <RegistryValue Root="HKCU" Key="Software\Munch" Name="InstallDir" Type="string" Value="[INSTALLDIR]" />
          </Component>
        </Directory>
      </Directory>
    </StandardDirectory>

    <Feature Id="MainProduct" Title="Munch" Level="1">
      <ComponentGroupRef Id="HarvestedFiles" />
      <ComponentRef Id="InstallDirComponent" />
    </Feature>
  </Package>

  <Fragment>
    <CustomAction Id="RunFirstRun"
      ExeCommand="WindowsPowerShell\v1.0\powershell.exe -ExecutionPolicy Bypass -NoProfile -File &quot;[INSTALLDIR]scripts\first-run.ps1&quot; -InstallDir &quot;[INSTALLDIR]&quot;"
      Directory="SystemFolder"
      Impersonate="yes"
      Execute="deferred"
      Return="check" />

    <InstallExecuteSequence>
      <Custom Action="RunFirstRun" After="InstallFinalize" Condition="NOT Installed" />
    </InstallExecuteSequence>
  </Fragment>
</Wix>
